# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Groq AI API (for AI trade validation)
GROQ_API_KEY=your_groq_api_key_here

# Webhook Configuration (for production on Render/Heroku)
WEBHOOK_MODE=true
WEBHOOK_URL=https://your-render-app-name.onrender.com
PORT=10000

# MT5 Configuration (optional - for broker-grade data)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# User Preferences
USER_TIMEZONE=Africa/Accra

# Signal Monitoring Settings
MIN_SIGNAL_CONFIDENCE=8
AI_APPROVAL_MIN_SCORE=7
PERFECT_SIGNAL_ENABLED=true

# Logging
LOG_LEVEL=INFO